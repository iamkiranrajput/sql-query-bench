# ============================================================================
# GitHub Copilot MCP SQL Assistant -- environment configuration
# Copy this file to .env and fill in your values.
# ============================================================================

# -- Application --------------------------------------------------------------
APP_NAME=GitHub Copilot MCP SQL Assistant
APP_VERSION=2.0.0
HOST=0.0.0.0
PORT=8742
DEBUG=False

# Skip FAISS to use keyword search only (faster startup, no network needed).
# Leave commented to enable FAISS when sentence-transformers is installed.
# SKIP_FAISS=1

# -- CORS ---------------------------------------------------------------------
# Comma-separated origins. Localhost added automatically when DEBUG=True.
ALLOWED_ORIGINS=http://localhost:4200

# -- Logging ------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
# Mask RFC-1918 10.x.x.x IPs in log files (console output stays untouched).
REDACT_INTERNAL_IPS=true

# -- Security -----------------------------------------------------------------
# REQUIRED: Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API_KEY protects every /api/* route via Bearer-token auth.
# Optional in local-dev deployments. Leave blank only when the server is
# reachable solely from localhost or a trusted private LAN.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
API_KEY=

# Comma-separated reverse-proxy IPs whose CF-Connecting-IP / X-Forwarded-For
# headers we trust. Default covers loopback only.
TRUSTED_PROXIES=127.0.0.1,::1

# -- Sessions & query limits --------------------------------------------------
SESSION_EXPIRY_HOURS=1
MAX_RESULT_ROWS=10000
QUERY_TIMEOUT_SECONDS=120
ENABLE_PERFORMANCE_PROFILING=True
ENABLE_DISTRIBUTED_TRACING=False

# -- Query-log retention ------------------------------------------------------
# Rolling retention (days) for the SQLite query log. 0 disables time-based pruning.
QUERY_LOG_RETENTION_DAYS=30
# Replace string literals in stored SQL/user_query with '***' before writing.
QUERY_LOG_REDACT_LITERALS=false

# -- GitHub Copilot token storage --------------------------------------------
# Base64-encoded 32-byte AES-256 key used to encrypt data/.copilot_token.json
# on non-Windows hosts. When empty AND not on Windows, the token is held in
# memory only and the user must re-authenticate after every restart -- the
# server refuses to write plaintext bearer tokens to disk.
# Generate with: python -c "import base64,os; print(base64.b64encode(os.urandom(32)).decode())"
COPILOT_TOKEN_ENC_KEY=

# Default Copilot model id (must be exposed via api.githubcopilot.com).
COPILOT_DEFAULT_MODEL=claude-opus-4

# Agent-loop budget for the Copilot service.
COPILOT_AGENT_WALL_CLOCK_SECONDS=480
COPILOT_AGENT_MAX_ITERATIONS=40
# When True, the agent enforces a structured response format
# (### Summary / ### Key Findings / ### Description). False (default) lets
# the agent answer in free-form, matching VS Code Copilot Chat.
COPILOT_STRUCTURED_RESPONSE=false

# -- MCP-over-HTTP transport (optional) --------------------------------------
# Mount the MCP server at /mcp so external MCP clients (MCP Inspector,
# Cursor, Claude Desktop, ...) can reach it. Off by default.
MCP_HTTP_ENABLED=false
MCP_HTTP_PATH=/mcp
MCP_HTTP_JSON_RESPONSE=false
# Auth mode for /mcp:
#   "static" -- shared bearer token in MCP_HTTP_BEARER_TOKEN (recommended)
#   "none"   -- open (DEV ONLY -- refused when DEBUG=False)
MCP_HTTP_AUTH_MODE=static
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
MCP_HTTP_BEARER_TOKEN=

# -- Optional: Preset Database Connection ------------------------------------
# Pre-fills the connection dialog on startup. All fields are optional.
PRESET_DB_NAME=
PRESET_DB_TYPE=postgresql
PRESET_DB_HOST=
PRESET_DB_PORT=5432
PRESET_DB_DATABASE=
PRESET_DB_USERNAME=
PRESET_DB_PASSWORD=

# -- Development -------------------------------------------------------------
# Set RELOAD=true for auto-reload during development (wipes in-memory sessions).
RELOAD=false
